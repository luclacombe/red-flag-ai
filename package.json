{
  "name": "red-flag-ai",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "AI-powered contract red-flag detector with clause-by-clause risk analysis",
  "license": "MIT",
  "author": "Luc Lacombe",
  "homepage": "https://red-flag-ai.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/luclacombe/red-flag-ai.git"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "test": "turbo test",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "seed": "node --env-file=.env.local --import=tsx/esm scripts/seed-knowledge-base.ts",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:reset": "supabase db reset",
    "setup": "supabase start && pnpm install && echo '\n✔ Supabase is running. Copy .env.example to .env.local and add your API keys:\n  cp .env.example .env.local\n  # Then add ANTHROPIC_API_KEY to .env.local\n  pnpm dev'"
  },
  "packageManager": "pnpm@10.30.3",
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "turbo": "^2.9.6",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  }
}
